ENV = 'production'

# base api
VUE_APP_BASE_API = 'http://localhost:8080/'

VUE_APP_OIDC_CONFIG={"authority": "https://idx-vuax.onrender.com/", "clientId": "implicit_client", "redirectUri": "https://idx-front.onrender.com/oidc-callback", "popupRedirectUri": "https://idx-front.onrender.com/oidc-popup-callback", "responseType": "id_token token", "scope": "openid email", "automaticSilentRenew": true, "automaticSilentSignin": false, "silentRedirectUri": "https://idx-front.onrender.com/silent-renew-oidc.html"}


